# ─────────────────────────────────────────────────────────────
# Solnest AI — environment variables
# Copy to .env.local for local dev; set the same keys in Vercel.
# ─────────────────────────────────────────────────────────────

# GoHighLevel (LeadConnector) — powers the intake form, calendar booking,
# and now the Build Session payment. One private integration / API key.
GHL_API_KEY=
GHL_LOCATION_ID=

# Calendars
# GHL_CALENDAR_ID           = default / strategy-call calendar
# GHL_BUILD_SESSION_CALENDAR_ID = the paid 60-min Build Session calendar
GHL_CALENDAR_ID=
GHL_BUILD_SESSION_CALENDAR_ID=

# ─────────────────────────────────────────────────────────────
# Build Session payment — GHL, NOT direct Stripe.
# Solnest holds NO Stripe key. Create ONE hosted payment page inside
# GoHighLevel for the $229 Build Session:
#   1. In GHL: Payments > Payment Links (or a funnel/store Order Form),
#      product = "Build Session", price = $229 one-time.
#   2. Make sure the location's Payments integration is connected to your
#      Stripe account (Payments > Integrations > Stripe). GHL charges the
#      card through YOUR Stripe; the website never sees a Stripe key.
#   3. Set the page's post-purchase redirect / "On submit" URL to:
#         https://solnestai.com/book?type=build
#      (so paid customers land on the calendar to pick their slot).
#   4. Paste the public payment-page URL below.
GHL_BUILD_SESSION_PAYMENT_URL=

# ─────────────────────────────────────────────────────────────
# Deprecated (no longer used — payment now goes through GHL):
#   STRIPE_SECRET_KEY
#   STRIPE_PRICE_BUILD_SESSION

# ─────────────────────────────────────────────────────────────
# Booking calendar — GHL-hosted widget (calendar + payment in one).
# Paste your GHL calendar's public booking URL (GHL > Calendars > your
# Build Session calendar > Permanent link / Embed). Enable payment on that
# calendar so the $229 is charged through your GHL/Stripe before booking.
# NEXT_PUBLIC_ so the /book page can embed it client-side. No API key needed.
NEXT_PUBLIC_GHL_BOOKING_URL=
